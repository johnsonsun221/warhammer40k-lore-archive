---
import Layout from '../../layouts/Layout.astro';
import FactionCard from '../../components/FactionCard.astro';
import { getCollection } from 'astro:content';

const factions = (await getCollection('factions', ({ data }) => !data.draft)).sort((a, b) =>
  a.data.title.localeCompare(b.data.title),
);
---

<Layout title="派系" description="從我個人觀點出發的 Warhammer 40,000 派系概覽。">
  <h1>派系</h1>

  <p>
    第 41 個千年中各方軍隊與勢力的清單,持續增補中,並附上我對自己收藏、遊玩或
    單純感興趣派系的筆記。其中多數頁面目前仍是待補內容 &mdash; 等我寫好後會陸續
    補上更多細節。
  </p>

  <div class="card-grid">
    {factions.map((faction) => <FactionCard faction={faction} />)}
  </div>
</Layout>
