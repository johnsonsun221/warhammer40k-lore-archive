---
import Layout from '../layouts/Layout.astro';
import LoreCard from '../components/LoreCard.astro';
import { getCollection } from 'astro:content';
import { withBase } from '../utils/url';

const loreEntries = (await getCollection('lore-entries', ({ data }) => !data.draft)).slice(0, 3);
---

<Layout title="首頁" description="一個由粉絲製作的個人 Warhammer 40,000 背景設定與時間軸資料庫。">
  <h1>背景設定資料庫</h1>

  <p>
    歡迎來到我在「遙遠未來的殘酷黑暗」中的個人角落。本站是我為 Warhammer 40,000
    設定整理筆記的進行中參考站 &mdash; 收錄我認為最重要事件的時間軸、我所在意的
    派系與背景設定的整理,以及(即將推出的)我的模型專案、戰報與同人創作。
  </p>

  <p>
    這裡的一切都是我用自己的話寫成,供我個人參考與自娛之用。Warhammer 40,000
    及所有相關財產皆屬於 Games Workshop &mdash; 完整免責聲明請見頁尾。
  </p>

  <hr class="divider" />

  <div class="quick-links">
    <a class="quick-link" href={withBase('timeline/')}>
      <h3>時間軸</h3>
      <p>依時間順序瀏覽設定中的重大事件。</p>
    </a>
    <a class="quick-link" href={withBase('lore/')}>
      <h3>背景設定索引</h3>
      <p>世界觀整理、派系與核心概念。</p>
    </a>
    <a class="quick-link" href={withBase('factions/')}>
      <h3>派系</h3>
      <p>第 41 個千年中的各方軍隊與勢力。</p>
    </a>
  </div>

  <h2>精選背景條目</h2>
  <div class="card-grid">
    {loreEntries.map((entry) => <LoreCard entry={entry} />)}
  </div>
</Layout>

<style>
  .quick-links {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
    margin: 1.5rem 0;
  }

  .quick-link {
    display: block;
    border: 1px solid var(--color-border);
    border-top: 3px solid var(--color-gold);
    border-radius: var(--radius);
    background: var(--color-bg-elevated);
    padding: 1rem;
  }

  .quick-link:hover,
  .quick-link:focus {
    border-color: var(--color-red);
    border-top-color: var(--color-gold);
  }

  .quick-link h3 {
    margin-top: 0;
    margin-bottom: 0.5rem;
  }

  .quick-link p {
    margin: 0;
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }
</style>
