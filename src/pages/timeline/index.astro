---
import Layout from '../../layouts/Layout.astro';
import TimelineEvent from '../../components/TimelineEvent.astro';
import EraNav from '../../components/EraNav.astro';
import { eraLabel } from '../../data/eras';
import { getCollection } from 'astro:content';

const events = (await getCollection('timeline-events', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.sortKey - b.data.sortKey,
);

// Group events by era, preserving chronological order within each era.
const groups: { era: string; events: typeof events }[] = [];
for (const event of events) {
  const last = groups[groups.length - 1];
  if (last && last.era === event.data.era) {
    last.events.push(event);
  } else {
    groups.push({ era: event.data.era, events: [event] });
  }
}

const activeEras = new Set(groups.map((g) => g.era));
---

<Layout title="時間軸" description="依我自己的整理排列的 Warhammer 40,000 重大事件時間軸。">
  <h1>時間軸</h1>

  <p>
    依時間順序帶你走過我認為對此設定最重要的事件,並按時代分組。日期採用設定內
    的紀年表示法(例如「M31」=第 31 個千年);本頁的排序為概略順序,依據我自己
    對時間軸的理解。
  </p>

  <EraNav activeEras={activeEras} />

  {
    groups.map((group) => (
      <section id={group.era}>
        <h2>{eraLabel(group.era)}</h2>
        {group.events.map((event) => <TimelineEvent event={event} />)}
      </section>
    ))
  }
</Layout>
