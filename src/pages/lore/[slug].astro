---
import Layout from '../../layouts/Layout.astro';
import Tag from '../../components/Tag.astro';
import { eraLabel } from '../../data/eras';
import { withBase } from '../../utils/url';
import { getCollection, getEntries, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('lore-entries', ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { title, summary, era, tags, relatedEntries, relatedEvents } = entry.data;
const { Content } = await render(entry);

const relatedLore = relatedEntries.length ? await getEntries(relatedEntries) : [];
const relatedTimeline = relatedEvents.length ? await getEntries(relatedEvents) : [];
---

<Layout title={title} description={summary}>
  <h1>{title}</h1>
  <div class="badges">
    <Tag label={eraLabel(era)} variant="era" />
    {tags.map((tag) => <Tag label={tag} />)}
  </div>

  <div class="content">
    <Content />
  </div>

  {
    (relatedLore.length > 0 || relatedTimeline.length > 0) && (
      <>
        <hr class="divider" />
        <h2>延伸閱讀</h2>
        <ul class="related-list">
          {relatedLore.map((related) => (
            <li>
              <a href={withBase(`lore/${related.id}/`)}>{related.data.title}</a> &mdash; 背景條目
            </li>
          ))}
          {relatedTimeline.map((related) => (
            <li>
              <a href={withBase('timeline/')}>{related.data.title}</a> &mdash; 時間軸事件({related.data.displayDate})
            </li>
          ))}
        </ul>
      </>
    )
  }
</Layout>

<style>
  .badges {
    margin-bottom: 1.5rem;
  }

  .content :global(h2:first-child) {
    margin-top: 0;
  }

  .related-list {
    padding-left: 1.25rem;
  }
</style>
