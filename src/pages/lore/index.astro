---
import Layout from '../../layouts/Layout.astro';
import LoreCard from '../../components/LoreCard.astro';
import { getCollection } from 'astro:content';

const entries = (await getCollection('lore-entries', ({ data }) => !data.draft)).sort((a, b) =>
  a.data.title.localeCompare(b.data.title),
);
---

<Layout title="背景設定索引" description="Warhammer 40,000 設定的背景整理與世界觀筆記索引。">
  <h1>背景設定索引</h1>

  <p>
    涵蓋此設定世界觀、各時代與核心概念大致脈絡的整理 &mdash; 是我自己的摘要與
    筆記,定位為快速參考,而非鉅細靡遺的百科全書。
  </p>

  <div class="card-grid">
    {entries.map((entry) => <LoreCard entry={entry} />)}
  </div>
</Layout>
