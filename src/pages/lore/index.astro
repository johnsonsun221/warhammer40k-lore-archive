---
import Layout from '../../layouts/Layout.astro';
import LoreCard from '../../components/LoreCard.astro';
import { getCollection } from 'astro:content';

const entries = (await getCollection('lore-entries', ({ data }) => !data.draft)).sort((a, b) =>
  a.data.title.localeCompare(b.data.title),
);
---

<Layout title="Lore Index" description="An index of lore write-ups and worldview notes on the Warhammer 40,000 setting.">
  <h1>Lore Index</h1>

  <p>
    Write-ups covering the broad strokes of the setting's worldview, eras,
    and core concepts &mdash; my own summaries and notes, meant as a quick
    reference rather than an exhaustive encyclopedia.
  </p>

  <div class="card-grid">
    {entries.map((entry) => <LoreCard entry={entry} />)}
  </div>
</Layout>
