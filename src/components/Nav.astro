---
import { withBase } from '../utils/url';

const links = [
  { href: withBase(''), label: '首頁' },
  { href: withBase('timeline/'), label: '時間軸' },
  { href: withBase('lore/'), label: '背景設定' },
  { href: withBase('factions/'), label: '派系' },
  { href: withBase('hobby/'), label: '模型誌' },
  { href: withBase('battle-reports/'), label: '戰報' },
  { href: withBase('fan-creations/'), label: '同人創作' },
  { href: withBase('wishlist/'), label: '願望清單' },
  { href: withBase('links/'), label: '連結' },
  { href: withBase('about/'), label: '關於' },
];

const currentPath = new URL(Astro.request.url).pathname;
---

<nav class="nav">
  <input type="checkbox" id="nav-toggle" class="nav-toggle" />
  <label for="nav-toggle" class="nav-toggle-label" aria-label="切換導覽選單">
    <span></span>
    <span></span>
    <span></span>
  </label>
  <ul class="nav-list">
    {
      links.map((link) => (
        <li>
          <a href={link.href} aria-current={currentPath === link.href ? 'page' : undefined}>
            {link.label}
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<style>
  .nav {
    position: relative;
  }

  .nav-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 1rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-list a {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 0.85rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.5rem 0.1rem;
    border-bottom: 2px solid transparent;
  }

  .nav-list a:hover,
  .nav-list a:focus,
  .nav-list a[aria-current='page'] {
    color: var(--color-gold);
    border-bottom-color: var(--color-gold);
  }

  .nav-toggle,
  .nav-toggle-label {
    display: none;
  }

  @media (max-width: 720px) {
    .nav-toggle-label {
      display: flex;
      flex-direction: column;
      gap: 4px;
      width: 28px;
      cursor: pointer;
      margin-bottom: 0.5rem;
    }

    .nav-toggle-label span {
      display: block;
      height: 2px;
      background: var(--color-gold);
    }

    .nav-list {
      max-height: 0;
      overflow: hidden;
      flex-direction: column;
      transition: max-height 0.2s ease;
    }

    .nav-toggle:checked ~ .nav-list {
      max-height: 30rem;
    }
  }
</style>
