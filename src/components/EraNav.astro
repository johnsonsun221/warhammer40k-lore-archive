---
import { eras } from '../data/eras';

interface Props {
  // Only show jump-links for eras that actually have events on the page.
  activeEras: Set<string>;
}

const { activeEras } = Astro.props;
const visibleEras = eras.filter((era) => activeEras.has(era.id));
---

<nav class="era-nav" aria-label="Jump to era">
  <ul>
    {
      visibleEras.map((era) => (
        <li>
          <a href={`#${era.id}`}>{era.label}</a>
        </li>
      ))
    }
  </ul>
</nav>

<style>
  .era-nav {
    position: sticky;
    top: 0;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    padding: 0.75rem 0;
    margin-bottom: 2rem;
    z-index: 10;
  }

  .era-nav ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .era-nav a {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
</style>
